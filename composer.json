{
    "name": "philiprehberger/php-password-strength",
    "description": "Password strength validation with entropy calculation and common password detection",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "password",
        "strength",
        "entropy",
        "security",
        "validation"
    ],
    "authors": [
        {
            "name": "Philip Rehberger"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\PasswordStrength\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\PasswordStrength\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
